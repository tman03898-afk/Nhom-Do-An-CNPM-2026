%%{init: {'theme': 'base'}}%%
erDiagram
  users {
    int user_id PK "NOT NULL"
    varchar username "NOT NULL"
    varchar full_name "NOT NULL"
    varchar email "NULL"
    varchar phone "NULL"
    varchar cccd "NULL"
    user_role role "NOT NULL"
    bool is_active "DEFAULT true"
    text password_hash "NOT NULL"
    date date_of_birth "NULL"
    text avatar_url "NULL"
    timestamp created_at "NOT NULL"
    timestamp updated_at "NOT NULL"
  }

  tenants {
    int tenant_id PK "NOT NULL"
    int user_id FK "NOT NULL UNIQUE"
    varchar phone "NULL"
    int room_id FK "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  rooms {
    int room_id PK "NOT NULL"
    varchar room_number "NOT NULL UNIQUE"
    smallint floor "NULL"
    numeric area "NOT NULL"
    smallint max_tenants "DEFAULT 1"
    numeric price "NOT NULL"
    room_status status "DEFAULT AVAILABLE"
    text description "NULL"
    varchar room_type "NULL"
    jsonb images "DEFAULT []"
    timestamptz hold_until "NULL"
    int active_hold_request_id "NULL"
    timestamp created_at "NOT NULL"
    timestamp updated_at "NOT NULL"
  }

  room_hold_requests {
    int hold_request_id PK "NOT NULL"
    int room_id FK "NOT NULL"
    varchar guest_name "NOT NULL"
    varchar guest_phone "NULL"
    varchar guest_email "NULL"
    date preferred_view_date "NULL"
    text note "NULL"
    hold_request_status request_status "DEFAULT NEW"
    varchar hold_kind "DEFAULT TEMP"
    timestamptz hold_until "NULL"
    text deposit_proof_url "NULL"
    timestamptz deposit_submitted_at "NULL"
    timestamptz deposit_verified_at "NULL"
    int deposit_verified_by FK "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  contracts {
    int contract_id PK "NOT NULL"
    int tenant_id FK "NOT NULL"
    int room_id FK "NOT NULL"
    int created_by FK "NOT NULL"
    date start_date "NOT NULL"
    date end_date "NULL"
    numeric rent_price "DEFAULT 0"
    numeric monthly_rent "NULL"
    numeric deposit "DEFAULT 0"
    contract_status status "DEFAULT ACTIVE"
    text notes "NULL"
    timestamp created_at "NOT NULL"
    timestamp updated_at "NOT NULL"
  }

  invoices {
    int invoice_id PK "NOT NULL"
    int tenant_id FK "NOT NULL"
    int contract_id FK "NOT NULL"
    date billing_month "NOT NULL"
    date due_date "NOT NULL"
    numeric rent_amount "DEFAULT 0"
    numeric electricity_amount "DEFAULT 0"
    numeric water_amount "DEFAULT 0"
    numeric other_fees_amount "DEFAULT 0"
    numeric total_amount "NOT NULL"
    invoice_status status "DEFAULT UNPAID"
    int created_by FK "NOT NULL"
    jsonb electricity_breakdown "NULL"
    jsonb water_breakdown "NULL"
    jsonb utility_meter_snapshot "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  payments {
    int payment_id PK "NOT NULL"
    int invoice_id FK "NOT NULL"
    numeric amount "NOT NULL"
    numeric amount_paid "NOT NULL"
    payment_method method "NOT NULL"
    payment_status status "DEFAULT PENDING"
    text proof_url "NULL"
    text note "NULL"
    int recorded_by FK "NOT NULL"
    timestamp paid_at "NOT NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  services {
    int service_id PK "NOT NULL"
    varchar name "NOT NULL UNIQUE"
    varchar unit "NULL"
    numeric price "DEFAULT 0"
    bool is_active "DEFAULT true"
    bool allow_tenant_subscription "DEFAULT true"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  service_fees {
    int fee_id PK "NOT NULL"
    varchar fee_name "NOT NULL"
    text description "NULL"
    numeric unit_price "NOT NULL"
    varchar unit "NOT NULL"
    fee_type fee_type "NOT NULL"
    bool is_active "NOT NULL"
  }

  utility_readings {
    int reading_id PK "NOT NULL"
    int room_id FK "NOT NULL"
    int contract_id FK "NULL"
    date billing_month "NULL"
    utility_type utility_type "NULL"
    numeric previous_value "DEFAULT 0"
    numeric current_value "DEFAULT 0"
    numeric electricity_old "NULL"
    numeric electricity_new "NULL"
    numeric water_old "NULL"
    numeric water_new "NULL"
    varchar electricity_img "NULL"
    varchar water_img "NULL"
    int recorded_by FK "NOT NULL"
    timestamp recorded_at "NOT NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  tenant_service_subscriptions {
    int subscription_id PK "NOT NULL"
    int tenant_id FK "NOT NULL"
    int service_id FK "NOT NULL"
    numeric monthly_price "DEFAULT 0"
    varchar status "ACTIVE|CANCELLED"
    timestamptz started_at "NOT NULL"
    timestamptz cancelled_at "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  tenant_fee_subscriptions {
    int id PK "NOT NULL"
    int tenant_id FK "NOT NULL"
    int fee_id FK "NOT NULL"
    numeric monthly_price "DEFAULT 0"
    varchar status "PENDING|ACTIVE|REJECTED|CANCELLED"
    date effective_from "NULL"
    timestamptz cancelled_at "NULL"
    timestamptz approved_at "NULL"
    int approved_by FK "NULL"
    timestamptz rejected_at "NULL"
    text reject_reason "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  incidents {
    int incident_id PK "NOT NULL"
    int room_id FK "NOT NULL"
    int reported_by FK "NOT NULL"
    int assigned_to FK "NULL"
    varchar title "NOT NULL"
    text description "NULL"
    incident_status status "DEFAULT OPEN"
    incident_priority priority "DEFAULT MEDIUM"
    numeric repair_cost "DEFAULT 0"
    varchar image_url "NULL"
    jsonb attachment_urls "DEFAULT []"
    timestamp created_at "NOT NULL"
    timestamp updated_at "NOT NULL"
  }

  notifications {
    int notification_id PK "NOT NULL"
    int user_id FK "NOT NULL"
    notification_type type "NULL"
    varchar title "NOT NULL"
    text message "NULL"
    text body "NULL"
    int reference_id "NULL"
    varchar reference_type "NULL"
    bool is_read "DEFAULT false"
    int created_by FK "NULL"
    timestamp created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  assets {
    int asset_id PK "NOT NULL"
    int room_id FK "NULL"
    varchar name "NOT NULL"
    int quantity "DEFAULT 1"
    asset_status status "DEFAULT OK"
    text note "NULL"
    timestamptz created_at "NOT NULL"
    timestamptz updated_at "NOT NULL"
  }

  users ||--o{ tenants : "user_id"
  rooms ||--o{ tenants : "room_id"
  rooms ||--o{ room_hold_requests : "room_id"
  users ||--o{ room_hold_requests : "deposit_verified_by"
  tenants ||--o{ contracts : "tenant_id"
  rooms ||--o{ contracts : "room_id"
  users ||--o{ contracts : "created_by"
  tenants ||--o{ invoices : "tenant_id"
  contracts ||--o{ invoices : "contract_id"
  users ||--o{ invoices : "created_by"
  invoices ||--o{ payments : "invoice_id"
  users ||--o{ payments : "recorded_by"
  rooms ||--o{ utility_readings : "room_id"
  contracts ||--o{ utility_readings : "contract_id"
  users ||--o{ utility_readings : "recorded_by"
  tenants ||--o{ tenant_service_subscriptions : "tenant_id"
  services ||--o{ tenant_service_subscriptions : "service_id"
  tenants ||--o{ tenant_fee_subscriptions : "tenant_id"
  service_fees ||--o{ tenant_fee_subscriptions : "fee_id"
  users ||--o{ tenant_fee_subscriptions : "approved_by"
  rooms ||--o{ incidents : "room_id"
  users ||--o{ incidents : "reported_by"
  users ||--o{ incidents : "assigned_to"
  users ||--o{ notifications : "user_id"
  users ||--o{ notifications : "created_by"
  rooms ||--o{ assets : "room_id"
